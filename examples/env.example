SOLANA_NETWORK=testnet
SOLANA_SOURCE=solana@validator.example.com
SOLANA_VALIDATOR_IDENTITY=REPLACE_WITH_VALIDATOR_IDENTITY_PUBKEY
# Backward-compatible alias accepted by the CLI:
# SOLANA_IDENTITY=REPLACE_WITH_VALIDATOR_IDENTITY_PUBKEY
SOLANA_RPC_URL=https://api.testnet.solana.com
SOLANA_MAX_DELINQUENT_PERCENT=10
SOLANA_LEDGER_PATH=/mnt/ledger
SOLANA_SNAPSHOT_PATH=/mnt/snapshots
SOLANA_STAKED_IDENTITY_PATH=/path/to/staked-identity.json
SOLANA_SOURCE_SECONDARY_IDENTITY_PATH=/path/to/source-secondary-identity.json
SOLANA_VOTE_KEYPAIR_PATH=/path/to/vote-account-keypair.json
SOLANA_SSH_KEY=

CHERRY_API_BASE=https://api.cherryservers.com/v1
CHERRY_PROJECT_ID=123456
CHERRY_PLAN=amd-ryzen-9950x
CHERRY_REGION=LT-Siauliai
CHERRY_IMAGE=ubuntu_24_04_64bit
CHERRY_HOSTNAME=solana-hotswap
CHERRY_SSH_KEY_ID=12345
CHERRY_KEY=REPLACE_WITH_CHERRY_API_TOKEN
CHERRY_SSH_KEY=/path/to/cherry-ssh-private-key
CHERRY_CYCLE=hourly
CHERRY_SPOT_MARKET=false
CHERRY_RENTAL_CAP=120m
CHERRY_VARIANT_IDS=

HOTSWAP_RUN_DIR=runs/cherry-attempts
CHERRY_KNOWN_HOSTS=runs/known_hosts
SSH_CONNECT_TIMEOUT=8
HOTSWAP_COMMAND=show-config
